<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TelaResultado">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/vinho"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="wrap_content"
            android:layout_height="91dp"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/cabecario" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:layout_marginTop="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Obrigado por Comprar na BELLA NAPOLI"
                    android:textColor="@color/vinho" />

                <TextView
                    android:id="@+id/txtExtrato"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Extrato:"
                    android:textColor="@color/vinho" />

                <TextView
                    android:id="@+id/txtValorConta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Valor da conta:"
                    android:textColor="@color/vinho" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="25dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnComprar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/botao"
                android:text="Novo Pedido"
                android:textColor="@color/vinho"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnInicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/botao"
                android:text="tela inicial"
                android:textColor="@color/vinho"
                app:backgroundTint="@null" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>