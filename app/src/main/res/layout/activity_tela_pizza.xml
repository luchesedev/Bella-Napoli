<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TelaPIzza">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/vinho"
        >

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="wrap_content"
            android:layout_height="108dp"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/cabecario" />

        <TextView
            android:id="@+id/textView10"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="115dp"
            android:text="PIZZAS"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="30dp"
            android:background="@drawable/botaoinvertido"
            android:text="Calcular Conta"
            android:textColor="@color/white"
            app:backgroundTint="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="135dp"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="15dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/img_peperoni"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:srcCompat="@drawable/peperoni" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textView9"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Pepperoni"
                            android:textColor="#4B0011"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="15dp"
                            android:text=" R$ 62.50"
                            android:textColor="#4B0011"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/btnMaispepperoni"
                    android:layout_width="32dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="285dp"
                    android:layout_marginTop="45dp"
                    android:padding="0px"
                    android:text="+"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/vinho" />

                <TextView
                    android:id="@+id/txtQntdPeperoni"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="270dp"
                    android:layout_marginTop="55dp"
                    android:text="0"
                    android:textColor="@color/vinho" />

                <Button
                    android:id="@+id/btnMenospepperoni"
                    android:layout_width="32dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="230dp"
                    android:layout_marginTop="45dp"
                    android:padding="0px"
                    android:text="-"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/vinho" />

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="15dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/img_mussarela"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:srcCompat="@drawable/mussarela" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textView8"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Mussarela"
                            android:textColor="#4B0011"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="15dp"
                            android:text=" R$ 55.90"
                            android:textColor="#4B0011"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/btnMaismussarela"
                    android:layout_width="32dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="285dp"
                    android:layout_marginTop="45dp"
                    android:padding="0px"
                    android:text="+"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/vinho" />

                <TextView
                    android:id="@+id/txtQntdMussarela"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="270dp"
                    android:layout_marginTop="55dp"
                    android:text="0"
                    android:textColor="@color/vinho" />

                <Button
                    android:id="@+id/btnMenosmussarela"
                    android:layout_width="32dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="230dp"
                    android:layout_marginTop="45dp"
                    android:padding="0px"
                    android:text="-"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/vinho" />

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="15dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/img_frangocatupiry"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:srcCompat="@drawable/frangocatupiry" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textView7"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Frango com Catupiry"
                            android:textColor="#4B0011"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="15dp"
                            android:text=" R$ 68.70"
                            android:textColor="#4B0011"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/btnMaisfrango"
                    android:layout_width="32dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="285dp"
                    android:layout_marginTop="45dp"
                    android:padding="0px"
                    android:text="+"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/vinho" />

                <TextView
                    android:id="@+id/txtQntdFrango"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="270dp"
                    android:layout_marginTop="55dp"
                    android:text="0"
                    android:textColor="@color/vinho" />

                <Button
                    android:id="@+id/btnMenosfrango"
                    android:layout_width="32dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="230dp"
                    android:layout_marginTop="45dp"
                    android:padding="0px"
                    android:text="-"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/vinho" />

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/img_atum"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:srcCompat="@drawable/atumcatupiry" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textView6"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Atum com Catupiry"
                            android:textColor="#4B0011"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="15dp"
                            android:text=" R$ 70.90"
                            android:textColor="#4B0011"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/btnMaisatum"
                    android:layout_width="32dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="285dp"
                    android:layout_marginTop="45dp"
                    android:padding="0px"
                    android:text="+"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/vinho" />

                <TextView
                    android:id="@+id/txtQntdAtum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="270dp"
                    android:layout_marginTop="55dp"
                    android:text="0"
                    android:textColor="@color/vinho" />

                <Button
                    android:id="@+id/btnMenosatum"
                    android:layout_width="32dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="230dp"
                    android:layout_marginTop="45dp"
                    android:padding="0px"
                    android:text="-"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:backgroundTint="@color/vinho" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>